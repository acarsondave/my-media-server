# VPN provider (nordvpn, protonvpn, mullvad, surfshark, etc.)
# Full list: https://github.com/qdm12/gluetun-wiki
VPN_PROVIDER=nordvpn
VPN_TYPE=wireguard

# WireGuard credentials
WIREGUARD_PRIVATE_KEY=

# OpenVPN credentials (use these instead if VPN_TYPE=openvpn)
# OPENVPN_USER=
# OPENVPN_PASSWORD=

# Comma-separated list of countries for server selection
VPN_COUNTRIES=Netherlands

# Timezone for all containers
TZ=Etc/UTC
